---
import VisitorStats from './VisitorStats.astro';

const currentYear = new Date().getFullYear();
---

<footer class="bg-white border-t border-stone-200 mt-auto">
  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-stone-500">
      <p>© {currentYear} 生态智能研究 · 基于 Astro 构建</p>
      <div class="flex flex-wrap items-center justify-center gap-3 sm:gap-4">
        <p class="text-stone-400">
          生态学 × 计算机科学 × 人工智能
        </p>
        <span class="text-stone-300">·</span>
        <a href="/playground" class="text-stone-400 hover:text-forest-600 transition-colors">
          Playground
        </a>
        <span class="text-stone-300">·</span>
        <VisitorStats />
      </div>
    </div>
  </div>
</footer>
