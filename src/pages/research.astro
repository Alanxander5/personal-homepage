---
import BaseLayout from '../layouts/BaseLayout.astro';

const researchAreas = [
  {
    id: 'wlz',
    title: '三峡库区消落带与面源污染拦截',
    icon: '🌊',
    description: '研究三峡库区周期性水位涨落形成的消落带生态系统，探讨植被恢复对氮磷等面源污染的拦截效果与机制。',
    keywords: ['消落带', '面源污染', '植被恢复', '氮磷拦截'],
  },
  {
    id: 'soil-microbe',
    title: '土壤微生物与氮磷循环',
    icon: '🌱',
    description: '土壤微生物是氮磷循环的重要参与者。我基于16S扩增子测序结果分析微生物群落结构，并结合功能基因相关文献，尝试理解微生物过程如何影响消落带的氮磷削减效果。',
    keywords: ['土壤微生物', '氮循环', '磷循环', '16S rRNA'],
  },
  {
    id: 'ai-ecology',
    title: 'AI for Ecology / 生态数据建模',
    icon: '🤖',
    description: '探索机器学习、深度学习在生态学数据建模中的应用，包括物种分布预测、生态系统服务评估等。',
    keywords: ['机器学习', '生态建模', '数据科学', 'Python'],
  },
  {
    id: 'remote-sensing',
    title: '遥感与环境监测',
    icon: '🛰️',
    description: '利用遥感数据监测生态环境变化，结合地面样点数据进行尺度转换与模型验证。',
    keywords: ['遥感', 'GEE', '植被指数', '环境监测'],
  },
];
---

<BaseLayout title="研究方向" description="研究方向 - 生态学与人工智能的交叉研究">
  <div class="max-w-5xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-semibold text-stone-800 mb-4">研究方向</h1>
    <p class="text-stone-600 mb-12 max-w-2xl">
      我的研究关注三峡库区周期性水位涨落形成的消落带生态系统，
      以及土壤微生物在氮磷循环中的作用。同时探索机器学习和遥感方法
      在生态学研究中的应用可能性。
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      {researchAreas.map((area) => (
        <div id={area.id} class="bg-white rounded-xl border border-stone-200 p-6 hover:shadow-md transition-shadow">
          <div class="flex items-start gap-4 mb-4">
            <span class="text-3xl">{area.icon}</span>
            <h2 class="text-xl font-medium text-stone-800 pt-1">{area.title}</h2>
          </div>
          <p class="text-stone-600 mb-4 leading-relaxed">
            {area.description}
          </p>
          <div class="flex flex-wrap gap-2">
            {area.keywords.map((kw) => (
              <span class="px-2 py-0.5 bg-stone-100 text-stone-500 rounded text-xs">
                {kw}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <section class="mt-12 bg-forest-50 rounded-xl p-6">
      <h2 class="text-lg font-medium text-forest-800 mb-3">我的立场</h2>
      <p class="text-stone-600 text-sm leading-relaxed">
        我相信计算方法对生态学有价值，但更相信扎实的野外工作和实验设计是理解生态过程的基础。
        技术工具是用来回答问题的，不是目的本身。我倾向于在充分理解生态学原理的前提下，
        谨慎地引入机器学习或遥感方法来扩展分析边界。
      </p>
    </section>
  </div>
</BaseLayout>
