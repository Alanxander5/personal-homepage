---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const tutorials = await getCollection('tutorials');
const sortedTutorials = tutorials.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="教程笔记" description="教程笔记 - 生态学数据处理与计算方法">
  <div class="max-w-5xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-semibold text-stone-800 mb-4">教程笔记</h1>
    <p class="text-stone-600 mb-12 max-w-2xl">
      这是我的学习方法笔记，记录从野外数据整理、微生物测序结果理解，
      到机器学习入门的探索过程。内容会随着学习和实践持续修订，欢迎交流和指正。
    </p>

    <div class="grid md:grid-cols-3 gap-6">
      {sortedTutorials.map((tutorial) => (
        <article class="bg-white rounded-xl border border-stone-200 p-6 hover:shadow-md transition-shadow">
          <div class="flex items-center gap-2 mb-3">
            <span class={`px-2 py-0.5 rounded text-xs ${
              tutorial.data.status === '已完成' ? 'bg-forest-50 text-forest-600' :
              tutorial.data.status === '更新中' ? 'bg-deepblue-50 text-deepblue-600' :
              'bg-stone-100 text-stone-500'
            }`}>
              {tutorial.data.status}
            </span>
            <span class="px-2 py-0.5 bg-stone-100 text-stone-500 rounded text-xs">
              {tutorial.data.difficulty}
            </span>
          </div>
          <h2 class="text-lg font-medium text-stone-800 mb-3 leading-snug">
            {tutorial.data.title}
          </h2>
          <p class="text-sm text-stone-500 mb-4 leading-relaxed">
            {tutorial.data.abstract}
          </p>
          <div class="flex flex-wrap gap-1">
            {tutorial.data.tags.map((tag) => (
              <span class="text-xs text-forest-600">
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>

    <section class="mt-12 bg-stone-100 rounded-xl p-6">
      <p class="text-sm text-stone-600">
        <span class="font-medium text-stone-700">使用说明：</span>
        这些内容是学习笔记和方法记录，并非系统课程。部分条目会随着后续实践持续修订，欢迎交流和指正。
      </p>
    </section>
  </div>
</BaseLayout>
