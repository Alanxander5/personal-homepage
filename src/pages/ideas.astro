---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const ideas = await getCollection('ideas');
const sortedIdeas = ideas.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const stageOrder = ['思考阶段', '文献调研阶段', '实验设计阶段', '进行中', '已搁置'];
const sortedByStage = [...sortedIdeas].sort((a, b) => {
  return stageOrder.indexOf(a.data.status) - stageOrder.indexOf(b.data.status);
});
---

<BaseLayout title="想法库" description="想法库 - 科研想法与研究思路">
  <div class="max-w-5xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-semibold text-stone-800 mb-4">想法库</h1>
    <p class="text-stone-600 mb-12 max-w-2xl">
      这里是研究构想库。有的只是一个模糊的问题意识，有的已有初步文献阅读基础，
      但都尚未经过充分验证。记录它们是为了便于日后回溯、修正和迭代。
    </p>

    <div class="space-y-6">
      {sortedByStage.map((idea, index) => (
        <article class="bg-white rounded-xl border border-stone-200 p-6 hover:shadow-md transition-shadow">
          <div class="flex items-start gap-4 mb-4">
            <span class="flex-shrink-0 w-8 h-8 bg-forest-50 text-forest-600 rounded-full flex items-center justify-center text-sm font-medium">
              {index + 1}
            </span>
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <h2 class="text-xl font-medium text-stone-800">{idea.data.title}</h2>
                <span class="px-2 py-0.5 bg-stone-100 text-stone-500 rounded text-xs">
                  {idea.data.status}
                </span>
              </div>
              <p class="text-stone-600 leading-relaxed mb-4">
                {idea.data.abstract}
              </p>
              <div class="flex flex-wrap gap-2">
                {idea.data.tags.map((tag) => (
                  <span class="px-2 py-0.5 bg-deepblue-50 text-deepblue-600 rounded text-xs">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <section class="mt-12 bg-stone-100 rounded-xl p-6">
      <p class="text-sm text-stone-600">
        <span class="font-medium text-stone-700">关于想法库：</span>
        这些是研究早期的不成熟构想，很可能随着学习深入被修正或放弃。
        记录的价值在于追踪思考的演变过程。
      </p>
    </section>
  </div>
</BaseLayout>
