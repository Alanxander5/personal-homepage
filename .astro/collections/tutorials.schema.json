{
  "$ref": "#/definitions/tutorials",
  "definitions": {
    "tutorials": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "入门",
            "初级",
            "中级",
            "高级"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "草稿",
            "更新中",
            "已完成"
          ]
        },
        "abstract": {
          "type": "string"
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "date",
        "tags",
        "difficulty",
        "status",
        "abstract"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}